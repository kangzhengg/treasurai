# Treasury.ai Backend Configuration

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8787

# Simulation Engine
SIMULATION_ENGINE_ENABLED=true

# Scenario Defaults
DEFAULT_SCENARIO=NORMAL
DEFAULT_FX_DAYS_HORIZON=30
DEFAULT_MARKET_RATE_USD=4.45
DEFAULT_MARKET_RATE_EUR=4.95

# Supplier Engine
SUPPLIER_NEGOTIATION_ENABLED=true
DEFAULT_SUPPLIER_RELATIONSHIP=TRANSACTIONAL

# Debug
DEBUG=false
LOG_LEVEL=info
